{
  "name": "cloud-speech-for-chrome",
  "version": "2.0.0",
  "private": true,
  "description": "Turn highlighted text into high-quality natural speech using multiple cloud providers (Amazon Polly, Azure, Google, OpenAI).",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.mjs",
    "dev:extension": "bun run --cwd apps/extension dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/extension build",
    "build:polly": "bun run --cwd apps/extension build:polly",
    "build:azure": "bun run --cwd apps/extension build:azure",
    "build:cloud": "bun run --cwd apps/extension build:cloud",
    "build:all": "bun run --cwd apps/extension build:all",
    "build:web": "bun run --cwd apps/web build",
    "zip:all": "bun run --cwd apps/extension zip:all",
    "typecheck": "bun run --cwd apps/extension typecheck && bun run --cwd apps/web typecheck",
    "test": "bun run --cwd apps/extension test",
    "test:coverage": "bun run --cwd apps/extension test:coverage",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "verify:zips": "node scripts/verify-zips.mjs",
    "test:e2e": "bun run build:cloud && bun run --cwd apps/extension test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,astro}": "biome check --write --no-errors-on-unmatched"
  },
  "author": "Vivswan Shah",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
