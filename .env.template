# Optional live provider tests. Copy to .env and provide newly rotated keys.
# This file is documentation only; never commit real credentials.
# With LIVE_PROVIDER_TESTS=1, each provider's test runs only when its
# variables below are filled in and skips otherwise.
LIVE_PROVIDER_TESTS=0

AZURE_API_KEY=
AZURE_REGION=eastus

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

GCP_API_KEY=

OPENAI_API_KEY=

# OpenAI-compatible server (the "custom" provider), e.g. http://localhost:4000/v1.
# Only the base URL is required; voices and model fall back to the server's defaults.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_VOICES=
OPENAI_COMPATIBLE_MODEL=
