{
  "name": "@cloud-speech/extension",
  "version": "2.0.0",
  "description": "Turn highlighted text into high-quality natural speech using multiple cloud providers (Amazon Polly, Azure, and more).",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --mode cloud",
    "build:polly": "wxt build --mode polly",
    "build:azure": "wxt build --mode azure",
    "build:cloud": "wxt build --mode cloud",
    "build:all": "bun run build:polly && bun run build:azure && bun run build:cloud",
    "zip": "wxt zip --mode cloud",
    "zip:polly": "wxt zip --mode polly",
    "zip:azure": "wxt zip --mode azure",
    "zip:all": "bun run zip:polly && wxt zip --mode azure && wxt zip --mode cloud",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "wxt prepare",
    "test:e2e": "playwright test"
  },
  "author": "Vivswan Shah",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-polly": "^3.1040.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "he": "^1.2.0",
    "lucide-react": "^0.545.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.13.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^3.4.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/he": "^1.2.3",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@wxt-dev/auto-icons": "^1.1.0",
    "@wxt-dev/i18n": "^0.2.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.4.0",
    "tailwindcss": "~4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.13",
    "yaml": "^2.9.0"
  }
}
