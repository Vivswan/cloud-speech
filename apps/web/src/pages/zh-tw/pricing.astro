---
import Base from "../../layouts/Base.astro";
import { type ProviderId, providers } from "../../lib/site";

const pricing: Record<
  ProviderId,
  {
    freeTier: string;
    costs: { label: string; price: string }[];
    officialUrl: string;
    officialLabel: string;
  }
> = {
  polly: {
    freeTier: "每月 500 萬標準 + 100 萬神經字元, 僅限前 12 個月",
    costs: [
      { label: "Standard", price: "$4" },
      { label: "Neural", price: "$16" },
      { label: "Generative", price: "$30" },
      { label: "Long-form", price: "$100" },
    ],
    officialUrl: "https://aws.amazon.com/polly/pricing/",
    officialLabel: "Polly 價格",
  },
  azure: {
    freeTier: "免費 (F0) 層級每月 50 萬神經字元; 每月重新計算",
    costs: [
      { label: "Neural", price: "約 $15-16" },
      { label: "HD/自訂語音", price: "較高" },
    ],
    officialUrl: "https://azure.microsoft.com/pricing/details/cognitive-services/speech-services/",
    officialLabel: "Azure 價格",
  },
  google: {
    freeTier:
      "每月 400 萬標準 + 100 萬 WaveNet 字元; 每月重新計算 (Studio 級語音另有小得多的獨立免費額度)",
    costs: [
      { label: "Standard", price: "約 $4" },
      { label: "WaveNet/Neural2", price: "約 $16" },
      { label: "Chirp HD", price: "較高" },
      { label: "Chirp 3 HD/Gemini-TTS", price: "約 $30" },
      { label: "Studio", price: "約 $160" },
    ],
    officialUrl: "https://cloud.google.com/text-to-speech/pricing",
    officialLabel: "Google 價格",
  },
  openai: {
    freeTier: "沒有免費額度; 按用量付費",
    costs: [
      { label: "tts-1", price: "約 $15" },
      { label: "tts-1-hd", price: "約 $30" },
      {
        label: "gpt-4o-mini-tts",
        price: "按 token 計費; 每 100 萬音訊 token 約 $12 (實際費用與 tts-1 差不多)",
      },
    ],
    officialUrl: "https://platform.openai.com/docs/pricing",
    officialLabel: "OpenAI 價格",
  },
  custom: {
    freeTier: "本機引擎可免費執行; 閘道依其後端費率計費",
    costs: [
      { label: "本機 (LocalAI、Speaches)", price: "免費" },
      { label: "透過閘道 (LiteLLM、Groq)", price: "依後端費率" },
    ],
    officialUrl: "https://docs.litellm.ai/docs/text_to_speech",
    officialLabel: "LiteLLM 文件",
  },
};

const rows = providers.map((provider) => ({ ...provider, ...pricing[provider.id] }));

const tips = [
  {
    lead: "多數內容用標準語音就好。",
    text: "價格只有神經語音的四分之一, 瀏覽文章綽綽有餘。",
  },
  {
    lead: "把神經語音留給重要的音訊:",
    text: "長篇閱讀、要保存的下載檔, 或需要仔細聆聽的內容。",
  },
  {
    lead: "節制使用 Generative、HD 與 Long-form 語音。",
    text: "它們比標準語音貴 2-25 倍。",
  },
  {
    lead: "善用每月重置的免費額度。",
    text: "Azure (50 萬神經字元) 與 Google (100 萬 WaveNet + 400 萬標準字元) 每月重新計算。搭配多家服務商, 輕度使用可以永遠免費。",
  },
  {
    lead: "在服務商的主控台監控用量",
    text: "(AWS 主控台 → Polly 用量報告、Azure 入口網站的計量、Google Cloud 帳單報告、OpenAI 用量儀表板)。",
  },
  {
    lead: "設定帳單警示",
    text: "以便在費用累積前收到通知。每家服務商都支援預算或支出警示。",
  },
];
---

<Base
  title="價格比較 · Cloud Speech"
  description="比較 Amazon Polly、Azure Speech、Google Cloud TTS 與 OpenAI 的文字轉語音費用: 免費額度、每字元價格與省錢訣竅。"
  active="pricing"
>
  <main class="mx-auto max-w-4xl px-6 py-12">
    <p><a class="link text-sm text-body" href="../">← 首頁</a></p>

    <header class="mt-8">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">服務商價格比較</h1>
      <p class="mt-4 max-w-3xl leading-relaxed text-body">
        擴充功能本身免費。您只需依合成的字元數付費給所選的雲端服務商 (每個字元都計費, 包括空格)。以下比較四家雲端服務商, 並附上適用於本機或代理伺服器的 OpenAI 相容選項。價格為約略值, 以美元計, 並會隨時間變動; 請以下方連結的官方定價頁面為準。
      </p>
    </header>

    {/* Phones: one card per provider. A four-column table can only sideways-
        scroll at this width, which hides the prices with no affordance. */}
    <div class="mt-10 space-y-4 sm:hidden">
      {
        rows.map((row) => (
          <section class="card p-5">
            <a class="flex items-center gap-2 font-semibold" href={`../setup/${row.id}/`}>
              <span class={`h-2.5 w-2.5 shrink-0 rounded-full ${row.dot}`} />
              <span class="link">{row.name}</span>
            </a>
            <p class="mt-3 text-sm text-body">
              <span class="font-medium text-strong">免費額度:</span> {row.freeTier}
            </p>
            <p class="mt-3 text-xs font-medium text-muted">每 100 萬字元費用</p>
            <ul class="mt-1 space-y-1 text-sm text-body">
              {row.costs.map((cost) => (
                <li>
                  {cost.label}: <strong class="font-semibold text-strong">{cost.price}</strong>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-sm">
              <a class="link" href={row.officialUrl}>
                {row.officialLabel}
              </a>
            </p>
          </section>
        ))
      }
    </div>

    <div class="card mt-10 hidden overflow-x-auto sm:block">
      {/* table-fixed with explicit widths: the browser's auto algorithm hands
          the longest header a huge column and strands the rest. */}
      <table class="w-full min-w-[640px] table-fixed text-left text-sm">
        <thead>
          <tr class="border-b border-edge bg-inset text-xs text-muted">
            <th class="w-[21%] rounded-tl-xl px-5 py-3 font-medium">服務商</th>
            <th class="w-[33%] px-5 py-3 font-medium">免費額度</th>
            <th class="w-[29%] px-5 py-3 font-medium">每 100 萬字元費用</th>
            <th class="w-[17%] rounded-tr-xl px-5 py-3 font-medium">官方價格</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-edge-soft">
          {
            rows.map((row) => (
              <tr class="align-top">
                <td class="px-5 py-4 whitespace-nowrap">
                  <a class="flex items-center gap-2 font-semibold" href={`../setup/${row.id}/`}>
                    <span class={`h-2.5 w-2.5 shrink-0 rounded-full ${row.dot}`} />
                    <span class="link">{row.name}</span>
                  </a>
                </td>
                <td class="px-5 py-4 text-body">{row.freeTier}</td>
                <td class="px-5 py-4 text-body">
                  <ul class="space-y-1">
                    {row.costs.map((cost) => (
                      <li>
                        {cost.label}: <strong class="font-semibold text-strong">{cost.price}</strong>
                      </li>
                    ))}
                  </ul>
                </td>
                <td class="px-5 py-4 whitespace-nowrap">
                  <a class="link" href={row.officialUrl}>
                    {row.officialLabel}
                  </a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">實際上這代表多少錢?</h2>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-body">
        100 萬字元大約可以聽 10-15 小時, 相當於兩本一般長度的小說。以每 100 萬字元 $4 (標準語音) 計算, 朗讀一篇約 1,500 字的文章只要 0.04 美分左右; 以每 100 萬字元 $16 (神經語音) 計算, 約六分之一美分。日常輕度使用通常完全落在 Azure 或 Google 的每月免費額度內。
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">省錢訣竅</h2>
      <ul class="mt-5 grid gap-4 sm:grid-cols-2">
        {
          tips.map((tip) => (
            <li class="rounded-lg border border-edge bg-card p-4 text-sm leading-relaxed text-body">
              <strong class="text-strong">{tip.lead}</strong> {tip.text}
            </li>
          ))
        }
      </ul>
    </section>

    <p class="mt-12 text-sm leading-relaxed text-body">
      準備好連接服務商了嗎? 從一份設定指南開始: <a class="link" href="../setup/polly/">Amazon Polly</a>、<a class="link" href="../setup/azure/">Azure Speech</a>、<a class="link" href="../setup/google/">Google Cloud TTS</a>、<a class="link" href="../setup/openai/">OpenAI</a>, 或<a class="link" href="../setup/custom/">OpenAI 相容伺服器</a>。
    </p>
  </main>
</Base>
