---
import Base from "../layouts/Base.astro";
import {
  chromeWebStoreUrl,
  firefoxAddonUrl,
  GITHUB_REPO_URL,
  providers,
  shortcuts,
} from "../lib/site";
---

<Base
  title="Cloud Speech: read any page aloud with cloud voices"
  description="Turn highlighted text into natural speech with Amazon Polly, Azure, Google Cloud TTS, or OpenAI. Setup guides for the Cloud Speech browser extension."
>
  <main>
    <!-- Hero -->
    <section
      class="mx-auto grid max-w-5xl grid-cols-[minmax(0,1fr)] items-center gap-14 px-6 pt-16 pb-24 lg:grid-cols-2 lg:pt-24"
    >
      <div>
        <h1 class="text-4xl leading-[1.12] font-bold tracking-tight sm:text-5xl">
          Read <span class="sweep">any page</span> aloud with the best cloud voices
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-body">
          Highlight text on any website and hear it in natural-sounding speech from Amazon Polly,
          Azure Speech, Google Cloud, or OpenAI. It runs on your own API keys, so your text goes
          only to the provider you choose.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            class="btn-primary"
            href={chromeWebStoreUrl}
            >Add to Chrome</a
          >
          {
            firefoxAddonUrl && (
              <a class="btn-primary" href={firefoxAddonUrl}>
                Add to Firefox
              </a>
            )
          }
          <a class="btn-secondary" href={GITHUB_REPO_URL}
            >View on GitHub</a
          >
        </div>
        <p class="mt-5 text-sm text-muted">
          Free and open source (MIT).
        </p>
      </div>

      <!-- Product mockup: highlighted text + floating player pill -->
      <div class="relative mx-auto w-full max-w-md" aria-hidden="true">
        <div class="card p-5 sm:p-6">
          <div class="flex items-center gap-1.5 border-b border-edge-soft pb-3.5">
            <span class="h-2.5 w-2.5 rounded-full bg-fill"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-fill"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-fill"></span>
            <span
              class="ml-3 flex-1 truncate rounded-md bg-inset px-3 py-1 font-mono text-[11px] text-faint"
              >en.wikipedia.org/wiki/Speech_synthesis</span
            >
          </div>
          <div class="mt-4 h-2.5 w-2/5 rounded bg-fill"></div>
          <p class="mt-4 text-[15px] leading-relaxed text-muted">
            The best neural voices now sound close to a human narrator.
            <span class="mark text-ink"
              >Select any paragraph on a page and the extension reads it to you in the voice you
              picked</span
            >, whether that page is an article, a paper, or an email.
          </p>
          <div class="mt-5 space-y-2.5">
            <div class="h-2 w-full rounded bg-inset"></div>
            <div class="h-2 w-11/12 rounded bg-inset"></div>
            <div class="h-2 w-3/5 rounded bg-inset"></div>
          </div>
        </div>
        <div
          class="absolute right-4 -bottom-5 flex items-center gap-3 rounded-full bg-inverse py-2 pr-4 pl-3 text-on-inverse shadow-lift sm:right-8"
        >
          <img src={`${import.meta.env.BASE_URL}icon.svg`} alt="" class="h-4 w-4" />
          <span class="eq"><i></i><i></i><i></i><i></i><i></i></span>
          <span class="text-xs font-medium text-on-inverse/70">Joanna &middot; 1.5&times;</span>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="border-y border-edge bg-card">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">What it does</h2>
          <p class="mt-3 text-sm leading-relaxed text-body">
            Connect one provider and you get all of this.
          </p>
        </div>
        <div class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
          <div>
            <h3 class="font-semibold">Voices from four providers, and beyond</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              Hundreds of voices in 40+ languages from Amazon Polly, Azure Speech, Google Cloud
              Text-to-Speech, and OpenAI, plus any OpenAI-compatible server, all in one voice
              picker.
            </p>
          </div>
          <div>
            <h3 class="font-semibold">Preview &amp; favorites</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              Press ▶ to hear a sample of any voice before choosing it, and star ★ your favorites
              so they stay at the top of the list.
            </p>
          </div>
          <div>
            <h3 class="font-semibold">Full playback control</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              A mini-player lets you pause, skip between chunks, jump +/-15 seconds, and change
              speed live. Read at 1x, 1.5x, or 2x straight from the right-click menu.
            </p>
          </div>
          <div>
            <h3 class="font-semibold">Download as audio</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              Save any selection as a high-quality MP3, for listening on the go or for your own
              audio notes.
            </p>
          </div>
          <div>
            <h3 class="font-semibold">Keyboard shortcuts</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              <kbd>{shortcuts.readAloud}</kbd> to read aloud, <kbd>{shortcuts.download}</kbd> to download.
              Customizable in your browser's extension settings.
            </p>
          </div>
          <div>
            <h3 class="font-semibold">Your keys, your data</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-body">
              You bring your own API credentials. Selected text goes straight from your browser
              to the provider you pick, with no middleman servers and no tracking.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="mx-auto max-w-5xl px-6 py-20">
      <h2 class="text-2xl font-semibold tracking-tight">How it works</h2>
      <ol class="mt-8 grid gap-5 sm:grid-cols-3">
        <li class="card p-6">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-inverse text-sm font-semibold text-on-inverse"
            >1</span
          >
          <h3 class="mt-4 font-semibold">Install the extension</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-body">
            Add
            <a
              class="link"
              href={chromeWebStoreUrl}
              >Cloud Speech</a
            >
            from the Chrome Web Store or Firefox Add-ons. It takes a few seconds.
          </p>
        </li>
        <li class="card p-6">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-inverse text-sm font-semibold text-on-inverse"
            >2</span
          >
          <h3 class="mt-4 font-semibold">Connect a provider</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-body">
            Follow one of the setup guides below to get an API key, then paste it into the
            extension's Settings and click <em>Save &amp; test</em>.
          </p>
        </li>
        <li class="card p-6">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-inverse text-sm font-semibold text-on-inverse"
            >3</span
          >
          <h3 class="mt-4 font-semibold">Select text &amp; listen</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-body">
            Highlight text on any page, right-click, and choose <em>Read aloud</em>, or press
            <kbd>{shortcuts.readAloud}</kbd>.
          </p>
        </li>
      </ol>
    </section>

    <!-- Setup guides -->
    <section id="guides" class="scroll-mt-20 border-t border-edge bg-card">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h2 class="text-2xl font-semibold tracking-tight">Set up your provider</h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-body">
          You only need one provider to get started. Each guide is written for non-developers and
          takes about 10 minutes; most guides also include a CLI shortcut if you'd rather use the
          terminal. The four cloud providers have generous free tiers except OpenAI, and running
          your own model is free.
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {
            providers.map((provider) => (
              <a class="group card card-hover p-6" href={`setup/${provider.id}/`}>
                <div class="flex items-center gap-3">
                  <span
                    class={`flex h-9 w-9 items-center justify-center rounded-full ${provider.ring}`}
                  >
                    <span class={`h-2.5 w-2.5 rounded-full ${provider.dot}`} />
                  </span>
                  <h3 class="font-semibold">{provider.name}</h3>
                  <span
                    aria-hidden="true"
                    class="ml-auto text-faint transition-colors group-hover:text-strong"
                  >
                    →
                  </span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-body">{provider.blurb}</p>
              </a>
            ))
          }
          <a class="group card card-hover p-6" href="setup/local/">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-faint/10">
                <span class="h-2.5 w-2.5 rounded-full bg-faint"></span>
              </span>
              <h3 class="font-semibold">Use any other model</h3>
              <span
                aria-hidden="true"
                class="ml-auto text-faint transition-colors group-hover:text-strong"
              >
                →
              </span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-body">
              Models we don't list directly: through a LiteLLM proxy, or an engine on your own machine.
            </p>
          </a>
        </div>
        <div class="mt-10 grid gap-x-10 gap-y-6 sm:grid-cols-2">
          <a class="group" href="pricing/">
            <h3 class="font-semibold transition-colors group-hover:text-body">
              Pricing comparison <span aria-hidden="true">→</span>
            </h3>
            <p class="mt-1 text-sm text-body">
              Free tiers and per-character costs, side by side.
            </p>
          </a>
          <a class="group" href="privacy/">
            <h3 class="font-semibold transition-colors group-hover:text-body">
              Privacy policy <span aria-hidden="true">→</span>
            </h3>
            <p class="mt-1 text-sm text-body">
              What the extension does and doesn't do with your data.
            </p>
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
