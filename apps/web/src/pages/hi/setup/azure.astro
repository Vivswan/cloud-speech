---
import Callout from "../../../components/Callout.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import Step from "../../../components/Step.astro";
import TroubleshootItem from "../../../components/TroubleshootItem.astro";
import Base from "../../../layouts/Base.astro";
import { shortcuts } from "../../../lib/site";
---

<Base
  title="Azure Speech सेटअप · Cloud Speech"
  description="Cloud Speech ब्राउज़र एक्सटेंशन के लिए Azure Speech का चरण-दर-चरण सेटअप: मुफ़्त Azure खाता और Speech संसाधन बनाएँ, फिर कुंजी और region जोड़ें।"
  active="azure"
>
  <main class="relative mx-auto max-w-3xl px-6 py-12">
    <p>
      <a class="link text-sm text-body" href="../../#guides">← सभी गाइड पर वापस</a>
    </p>

    <header class="mt-8">
      <p
        class="inline-flex items-center gap-2 rounded-full bg-azure/10 px-3 py-1 text-xs font-medium text-body"
      >
        <span class="h-2 w-2 rounded-full bg-azure"></span>
        सेटअप गाइड
      </p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">Azure Speech सेट करें</h1>
      <p class="mt-4 leading-relaxed text-body">
        Microsoft की Azure Speech सेवा बहुत सी भाषाओं में उच्च गुणवत्ता की neural आवाज़ें देती
        है, और इसका मुफ़्त टियर <em>हर महीने</em> नया मिलता है, इसलिए नियमित सुनने के लिए यह
        अच्छा विकल्प है। यह गाइड आपको चरण-दर-चरण सब सिखाता है। इसमें लगभग 10 मिनट लगते हैं।
      </p>
      <OnThisPage
        items={[
          { href: "#steps", label: "सेटअप के चरण" },
          { href: "#costs", label: "लागत" },
          { href: "#remove", label: "एक्सेस हटाएँ" },
          { href: "#cli", label: "CLI सेटअप" },
          { href: "#troubleshooting", label: "समस्या निवारण" },
        ]}
      />
    </header>

    <div class="card mt-8 p-5">
      <h2 class="text-sm font-semibold">आपको क्या चाहिए</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-relaxed text-body">
        <li>
          एक Microsoft खाता और एक मुफ़्त Azure खाता (साइन-अप के लिए भुगतान का तरीक़ा ज़रूरी है)
        </li>
        <li>लगभग 10 मिनट</li>
      </ul>
    </div>

    <ol
      id="steps"
      class="relative mt-12 scroll-mt-24 space-y-12 before:absolute before:top-2 before:bottom-2 before:left-4 before:w-px before:bg-fill"
    >
      <Step n={1} title="मुफ़्त Azure खाता बनाएँ">
        <p>अगर आपके पास अभी Azure खाता नहीं है:</p>
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>
            <a class="link" href="https://azure.microsoft.com/free/">azure.microsoft.com/free</a>
            पर जाएँ
          </li>
          <li>
            <strong>Start free</strong> पर क्लिक करें और Microsoft खाते से साइन इन करें (या नया
            बनाएँ)
          </li>
          <li>पहचान सत्यापन पूरा करें और भुगतान का तरीक़ा जोड़ें</li>
        </ol>
        <p class="text-muted">
          मुफ़्त (F0) Speech टियर पर कुछ नहीं कटता। कार्ड सिर्फ़ पहचान सत्यापन और आपके ख़ुद चुने
          हुए सशुल्क टियरों के लिए इस्तेमाल होता है।
        </p>
      </Step>

      <Step n={2} title="Speech संसाधन बनाएँ">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>
            <a class="link" href="https://portal.azure.com">Azure Portal</a> में साइन इन करें
          </li>
          <li><strong>Create a resource</strong> पर क्लिक करके <strong>Speech</strong> खोजें</li>
          <li>
            <strong>Speech</strong> चुनें (Microsoft का, "AI + Machine Learning" के अंतर्गत) और
            <strong>Create</strong> पर क्लिक करें
          </li>
          <li>अपनी सदस्यता चुनें और एक <strong>resource group</strong> बनाएँ (या चुनें)</li>
          <li>
            अपने नज़दीक का <strong>Region</strong> चुनें, जैसे <span class="value">eastus</span>,
            <span class="value">westeurope</span> या <span class="value">southeastasia</span>
          </li>
          <li>संसाधन को कोई नाम दें, जैसे <span class="value">cloud-speech-tts</span></li>
          <li>
            <strong>Pricing tier</strong> में <strong>Free (F0)</strong> चुनें; ज़रूरत बढ़े तो
            बाद में Standard (S0) पर जा सकते हैं
          </li>
          <li><strong>Review + create</strong>, फिर <strong>Create</strong> पर क्लिक करें</li>
        </ol>
        <p class="text-muted">
          चुना हुआ region याद रखें। अगले चरण में एक्सटेंशन को इसकी ज़रूरत पड़ेगी।
        </p>
      </Step>

      <Step n={3} title="अपनी कुंजी और region कॉपी करें">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>तैनाती पूरी होते ही <strong>Go to resource</strong> पर क्लिक करें</li>
          <li>
            बाएँ मेनू में <strong>Keys and Endpoint</strong> खोलें ("Resource Management" के
            अंतर्गत)
          </li>
          <li><strong>Key 1</strong> कॉपी करें (दोनों में से कोई भी कुंजी चलेगी)</li>
          <li>
            उसी पेज पर दिखा <strong>Location/Region</strong> नोट करें, जैसे
            <span class="value">eastus</span>
          </li>
        </ol>
        <Callout title="सुरक्षा चेतावनी">
          कुंजी को पासवर्ड की तरह रखें; जिसके पास यह होगी, वह आपका Speech संसाधन इस्तेमाल कर
          सकता है। उसी पेज से आप इसे कभी भी फिर से बना सकते हैं।
        </Callout>
      </Step>

      <Step n={4} title="एक्सटेंशन जोड़ें">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>ब्राउज़र टूलबार में एक्सटेंशन आइकन पर क्लिक करें</li>
          <li><strong>सेटिंग्स → Azure Speech</strong> खोलें</li>
          <li>अपनी <strong>Key</strong> चिपकाएँ</li>
          <li>अपना <strong>Region</strong> लिखें (जैसे <span class="value">eastus</span>)</li>
          <li><strong>सहेजें और जाँचें</strong> पर क्लिक करें</li>
        </ol>
        <p>
          जाँच पास होते ही Azure की आवाज़ें वॉइस पिकर में दिखने लगती हैं। किसी भी आवाज़ का नमूना
          सुनने के लिए ▶ दबाएँ और पसंद आने वाली आवाज़ों पर ★ लगाएँ। फिर किसी भी पेज पर टेक्स्ट
          हाइलाइट करें, राइट-क्लिक करके <em>पढ़कर सुनाएँ</em> चुनें, या <kbd>{shortcuts.readAloud}</kbd> दबाएँ।
        </p>
      </Step>
    </ol>

    <!-- Costs -->
    <section class="card mt-12 scroll-mt-24 p-6" id="costs">
      <h2 class="flex items-center gap-2.5 text-lg font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-azure"></span>
        लागत
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-body">
        <strong>Free (F0)</strong> टियर में लगभग
        <strong>5 लाख (0.5M) neural अक्षर प्रति माह</strong> शामिल हैं, और यह हर महीने नया मिलता
        है, सिर्फ़ पहले साल नहीं। Standard (S0) टियर पर neural आवाज़ों की लागत लगभग
        <strong>$15–16 प्रति 10 लाख अक्षर</strong> है; HD और कस्टम आवाज़ें महँगी हैं। क़ीमतें
        region के अनुसार अलग होती हैं और समय के साथ बदलती हैं, इसलिए देखें
        <a
          class="link"
          href="https://azure.microsoft.com/pricing/details/cognitive-services/speech-services/"
          >Azure Speech का आधिकारिक pricing पेज</a
        >
        और हमारी <a class="link" href="../../pricing/">प्रदाताओं की तुलना</a>।
      </p>
    </section>

    <!-- Remove access -->
    <section class="card mt-12 scroll-mt-24 p-6" id="remove">
      <h2 class="flex items-center gap-2.5 text-lg font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-azure"></span>
        काम पूरा होने पर एक्सेस हटाएँ
      </h2>
      <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-relaxed text-body">
        <li>
          <a class="link" href="https://portal.azure.com">Azure Portal</a> में अपना Speech
          संसाधन खोजें (या उसका resource group खोलें)।
        </li>
        <li>
          संसाधन चुनकर <strong>Delete</strong> करें। दोनों कुंजियाँ उसी पल काम करना बंद कर देती
          हैं। पूरा resource group हटाने से उसके अंदर की हर चीज़ हट जाती है।
        </li>
        <li>
          एक्सटेंशन में <strong>सेटिंग्स → Azure Speech</strong> खोलकर सहेजी हुई कुंजी मिटा दें
          (या प्रदाता को बंद कर दें)।
        </li>
      </ol>
    </section>

    <!-- CLI alternative -->
    <section class="card mt-12 scroll-mt-24 p-6" id="cli">
      <h2 class="flex items-center gap-2.5 text-lg font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-azure"></span>
        कमांड लाइन पसंद है?
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-body">
        <a class="link" href="https://learn.microsoft.com/cli/azure/install-azure-cli">Azure
        CLI</a> से यह वही मुफ़्त-टियर Speech संसाधन बनाता है जो ऊपर के चरणों में बना था:
      </p>
      <pre class="cli-block mt-4"><code is:raw>az login
az group create --name tts --location eastus
az cognitiveservices account create --name my-speech --resource-group tts \
  --kind SpeechServices --sku F0 --location eastus --yes
az cognitiveservices account keys list --name my-speech --resource-group tts
# Paste key1 into the extension, with region "eastus".</code></pre>
      <p class="mt-4 text-sm leading-relaxed text-body">और बाद में सब हटाने के लिए:</p>
      <pre class="cli-block mt-4"><code is:raw>az cognitiveservices account delete --name my-speech --resource-group tts
az group delete --name tts --yes</code></pre>
    </section>

    <!-- Troubleshooting -->
    <section class="mt-12 scroll-mt-24" id="troubleshooting">
      <h2 class="text-xl font-semibold tracking-tight">समस्या निवारण</h2>
      <div class="card mt-4 divide-y divide-edge-soft">
        <TroubleshootItem title='"क्रेडेंशियल गायब या अमान्य हैं"'>
          <p>
            चिपकाए हुए मान दोबारा जाँचें; सबसे आम कारण कोई फालतू रिक्त स्थान या छूटा हुआ अक्षर
            होता है। पक्का करें कि region आपके Speech संसाधन से मेल खाता है (जैसे
            <span class="value">eastus</span>) और कुंजी फिर से नहीं बनाई गई है। फिर
            <strong>सहेजें और जाँचें</strong> पर दोबारा क्लिक करें।
          </p>
        </TroubleshootItem>
        <TroubleshootItem title='"Access denied" त्रुटियाँ'>
          <p>
            आपकी कुंजी सही है पर अनुमति या कोटा नहीं है। जाँचें कि संसाधन हटाया या हिलाया नहीं
            गया, आपका खाता ठीक स्थिति में है और आपने F0 टियर का मासिक कोटा पार नहीं किया है।
          </p>
        </TroubleshootItem>
      </div>
      <p class="mt-3 text-sm text-body">
        ऑडियो न बजने, आवाज़ों के गायब होने या कीबोर्ड शॉर्टकट की समस्याओं के लिए
        <a class="link" href="../../troubleshooting/">समस्या निवारण गाइड</a> देखें।
      </p>
    </section>

    <p class="mt-10 text-sm leading-relaxed text-body">
      कोई और प्रदाता चाहिए? देखें
      <a class="link" href="../polly/">Amazon Polly</a>,
      <a class="link" href="../google/">Google Cloud TTS</a> या
      <a class="link" href="../openai/">OpenAI</a>।
    </p>
  </main>
</Base>
