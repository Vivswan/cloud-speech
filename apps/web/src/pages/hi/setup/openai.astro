---
import Callout from "../../../components/Callout.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import Step from "../../../components/Step.astro";
import TroubleshootItem from "../../../components/TroubleshootItem.astro";
import Base from "../../../layouts/Base.astro";
import { shortcuts } from "../../../lib/site";
---

<Base
  title="OpenAI सेटअप · Cloud Speech"
  description="Cloud Speech ब्राउज़र एक्सटेंशन के लिए OpenAI का चरण-दर-चरण सेटअप: OpenAI खाता बनाएँ, API कुंजी बनाएँ और एक्सटेंशन जोड़ें।"
  active="openai"
>
  <main class="relative mx-auto max-w-3xl px-6 py-12">
    <p>
      <a class="link text-sm text-body" href="../../#guides">← सभी गाइड पर वापस</a>
    </p>

    <header class="mt-8">
      <p
        class="inline-flex items-center gap-2 rounded-full bg-openai/10 px-3 py-1 text-xs font-medium text-body"
      >
        <span class="h-2 w-2 rounded-full bg-openai"></span>
        सेटअप गाइड
      </p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">OpenAI सेट करें</h1>
      <p class="mt-4 leading-relaxed text-body">
        OpenAI की text-to-speech आवाज़ें (tts-1, tts-1-hd और gpt-4o-mini-tts) बहुत अभिव्यक्ति
        भरी हैं, और चारों क्लाउड प्रदाताओं में इसका सेटअप सबसे आसान है: एक API कुंजी, न कोई
        region, न क्लाउड कंसोल की भूलभुलैया। इसमें लगभग 5 मिनट लगते हैं।
      </p>
      <OnThisPage
        items={[
          { href: "#steps", label: "सेटअप के चरण" },
          { href: "#costs", label: "लागत" },
          { href: "#remove", label: "एक्सेस हटाएँ" },
          { href: "#troubleshooting", label: "समस्या निवारण" },
        ]}
      />
    </header>

    <div class="card mt-8 p-5">
      <h2 class="text-sm font-semibold">आपको क्या चाहिए</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-relaxed text-body">
        <li>बिलिंग सेट किया हुआ OpenAI प्लेटफ़ॉर्म खाता (speech के लिए कोई मुफ़्त टियर नहीं है)</li>
        <li>लगभग 5 मिनट</li>
      </ul>
    </div>

    <ol
      id="steps"
      class="relative mt-12 scroll-mt-24 space-y-12 before:absolute before:top-2 before:bottom-2 before:left-4 before:w-px before:bg-fill"
    >
      <Step n={1} title="OpenAI खाता बनाएँ">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>
            <a class="link" href="https://platform.openai.com">platform.openai.com</a> पर जाकर
            साइन अप करें (या साइन इन करें)
          </li>
          <li>
            <strong>Settings → Billing</strong> खोलकर भुगतान का तरीक़ा जोड़ें या प्रीपेड क्रेडिट
            ख़रीदें; API का उपयोग जितना इस्तेमाल, उतना भुगतान वाला है और ChatGPT की सदस्यता से
            अलग है
          </li>
        </ol>
        <p class="text-muted">सुझाव: प्रीपेड क्रेडिट से आप अधिकतम ख़र्च की सीमा तय कर सकते हैं।</p>
      </Step>

      <Step n={2} title="API कुंजी बनाएँ">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>
            <a class="link" href="https://platform.openai.com/api-keys"
              >platform.openai.com/api-keys</a
            >
            पर जाएँ
          </li>
          <li><strong>Create new secret key</strong> पर क्लिक करें</li>
          <li>उसे कोई नाम दें, जैसे <span class="value">Cloud Speech extension</span></li>
          <li>
            <strong>Create secret key</strong> पर क्लिक करें और कुंजी कॉपी करें (यह
            <span class="value">sk-</span> से शुरू होती है)
          </li>
        </ol>
        <Callout title="सुरक्षा चेतावनी">
          कुंजी तुरंत कॉपी कर लें, क्योंकि OpenAI उसे दोबारा कभी नहीं दिखाएगा। इसे गुप्त रखें;
          जिसके पास यह होगी, वह आपके क्रेडिट ख़र्च कर सकता है। उसी पेज से आप इसे कभी भी रद्द कर
          सकते हैं।
        </Callout>
      </Step>

      <Step n={3} title="एक्सटेंशन जोड़ें">
        <ol class="list-decimal space-y-1.5 pl-5 marker:text-faint">
          <li>ब्राउज़र टूलबार में एक्सटेंशन आइकन पर क्लिक करें</li>
          <li><strong>सेटिंग्स → OpenAI</strong> खोलें</li>
          <li>अपनी <strong>API कुंजी</strong> चिपकाएँ</li>
          <li><strong>सहेजें और जाँचें</strong> पर क्लिक करें</li>
        </ol>
        <p>
          जाँच पास होते ही OpenAI की आवाज़ें वॉइस पिकर में दिखने लगती हैं। किसी भी आवाज़ का
          नमूना सुनने के लिए ▶ दबाएँ और पसंद आने वाली आवाज़ों पर ★ लगाएँ। फिर किसी भी पेज पर
          टेक्स्ट हाइलाइट करें, राइट-क्लिक करके <em>पढ़कर सुनाएँ</em> चुनें, या <kbd>{shortcuts.readAloud}</kbd> दबाएँ।
        </p>
        <Callout title="जानने लायक़" tone="neutral">
          OpenAI की आवाज़ें <strong>सिर्फ़ गति नियंत्रण</strong> समझती हैं। pitch और वॉल्यूम के
          स्लाइडर इन पर लागू नहीं होते (Polly, Azure और Google की आवाज़ों पर होते हैं)।
        </Callout>
      </Step>
    </ol>

    <!-- Costs -->
    <section class="card mt-12 scroll-mt-24 p-6" id="costs">
      <h2 class="flex items-center gap-2.5 text-lg font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-openai"></span>
        लागत
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-body">
        Text-to-speech के लिए OpenAI में <strong>कोई मुफ़्त टियर नहीं</strong> है। मोटे तौर पर
        <strong>tts-1</strong> की लागत लगभग <strong>$15 प्रति 10 लाख अक्षर</strong> है और
        <strong>tts-1-hd</strong> की उससे लगभग दोगुनी। <strong>gpt-4o-mini-tts</strong> का बिल
        अलग तरह से बनता है, अक्षरों के बजाय टेक्स्ट-इनपुट और ऑडियो-आउटपुट token के हिसाब से,
        लेकिन व्यवहार में प्रति मिनट ऑडियो का ख़र्च लगभग tts-1 जितना ही बैठता है। देखें
        <a class="link" href="https://platform.openai.com/docs/pricing"
          >OpenAI का आधिकारिक pricing पेज</a
        >
        और हमारी <a class="link" href="../../pricing/">प्रदाताओं की तुलना</a>।
      </p>
    </section>

    <!-- Remove access -->
    <section class="card mt-12 scroll-mt-24 p-6" id="remove">
      <h2 class="flex items-center gap-2.5 text-lg font-semibold">
        <span class="h-2.5 w-2.5 rounded-full bg-openai"></span>
        काम पूरा होने पर एक्सेस हटाएँ
      </h2>
      <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-relaxed text-body">
        <li>
          <a class="link" href="https://platform.openai.com/api-keys">platform.openai.com/api-keys</a>
          खोलें, अपनी बनाई कुंजी ढूँढ़ें और <strong>Revoke</strong> चुनें। वह उसी पल काम करना
          बंद कर देती है।
        </li>
        <li>
          एक्सटेंशन में <strong>सेटिंग्स → OpenAI</strong> खोलकर सहेजी हुई कुंजी मिटा दें (या
          प्रदाता को बंद कर दें)।
        </li>
      </ol>
      <p class="mt-3 text-sm leading-relaxed text-body">
        कुंजियों के प्रबंधन के लिए OpenAI के पास कोई कमांड-लाइन टूल नहीं है; कुंजियाँ सिर्फ़
        डैशबोर्ड पर बनती और रद्द होती हैं।
      </p>
    </section>

    <!-- Troubleshooting -->
    <section class="mt-12 scroll-mt-24" id="troubleshooting">
      <h2 class="text-xl font-semibold tracking-tight">समस्या निवारण</h2>
      <div class="card mt-4 divide-y divide-edge-soft">
        <TroubleshootItem title='"क्रेडेंशियल गायब या अमान्य हैं"'>
          <p>
            चिपकाई हुई कुंजी दोबारा जाँचें; सबसे आम कारण कोई फालतू रिक्त स्थान होता है। देखें कि
            कुंजी रद्द तो नहीं हुई और आपके खाते में बिलिंग सेट है या क्रेडिट बचे हैं। फिर
            <strong>सहेजें और जाँचें</strong> पर दोबारा क्लिक करें।
          </p>
        </TroubleshootItem>
        <TroubleshootItem title='"Access denied" या rate-limit त्रुटियाँ'>
          <p>
            जाँचें कि आपका खाता ठीक स्थिति में है, क्रेडिट बचे हैं और rate limit पार नहीं हुई
            है। उपयोग बढ़ने के साथ सीमाएँ अपने आप बढ़ती जाती हैं।
          </p>
        </TroubleshootItem>
      </div>
      <p class="mt-3 text-sm text-body">
        ऑडियो न बजने, आवाज़ों के गायब होने या कीबोर्ड शॉर्टकट की समस्याओं के लिए
        <a class="link" href="../../troubleshooting/">समस्या निवारण गाइड</a> देखें।
      </p>
    </section>

    <p class="mt-10 text-sm leading-relaxed text-body">
      कोई और प्रदाता चाहिए? देखें
      <a class="link" href="../polly/">Amazon Polly</a>,
      <a class="link" href="../azure/">Azure Speech</a> या
      <a class="link" href="../google/">Google Cloud TTS</a>।
    </p>
  </main>
</Base>
