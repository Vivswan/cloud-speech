---
interface Props {
  n: number;
  title: string;
}

const { n, title } = Astro.props;
---

<li class="relative pl-14">
  <span
    class="absolute top-0 left-0 flex h-8 w-8 items-center justify-center rounded-full bg-inverse text-sm font-semibold text-on-inverse"
    >{n}</span
  >
  <h2 class="pt-1 text-lg font-semibold">{title}</h2>
  <div class="mt-3 space-y-3 text-[15px] leading-relaxed text-body">
    <slot />
  </div>
</li>
