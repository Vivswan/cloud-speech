---
interface Props {
  items: { href: string; label: string }[];
}

const { items } = Astro.props;
---

<nav class="mt-4 text-sm text-stone-600 xl:hidden" aria-label="On this page">
  <span class="font-medium text-stone-500">On this page:</span>
  <ul class="mt-1.5 space-y-1">
    {
      items.map((item) => (
        <li>
          <a class="link" href={item.href}>
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

{/* Sidebar variant; requires `relative` on the page's <main> to anchor against. */}
<div class="absolute top-0 bottom-0 left-full hidden xl:block">
  <nav class="sticky top-24 ml-10 w-44 text-sm text-stone-600" aria-label="On this page">
    <span class="font-medium text-stone-500">On this page</span>
    <ul class="mt-2 space-y-1.5">
      {
        items.map((item) => (
          <li>
            <a class="link" href={item.href}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>
