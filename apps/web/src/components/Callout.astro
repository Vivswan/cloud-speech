---
interface Props {
  title: string;
  tone?: "amber" | "neutral";
}

const { title, tone = "amber" } = Astro.props;
const isAmber = tone === "amber";
---

<div
  class={isAmber
    ? "rounded-lg border border-note-edge bg-note p-4"
    : "rounded-lg border border-edge bg-inset p-4"}
>
  <p class={isAmber ? "text-sm font-semibold text-note-text" : "text-sm font-semibold"}>{title}</p>
  <div
    class={isAmber
      ? "mt-1 text-sm leading-relaxed text-note-text/90"
      : "mt-1 text-sm leading-relaxed text-body"}
  >
    <slot />
  </div>
</div>
